generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  qlikAppId    String   @map("qlik_app_id")
  qlikSheetId  String?  @map("qlik_sheet_id")
  qlikSpaceId  String?  @map("qlik_space_id")
  title        String
  description  String?
  category     String?
  tags         String[]
  ownerName    String?  @map("owner_name")
  dataSources  String[] @map("data_sources")
  lastReload   DateTime? @map("last_reload") @db.Timestamptz
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  roleAccess   RoleReportAccess[]
  accessLogs   AccessLog[]

  @@index([category])
  @@index([isActive])
  @@map("reports")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  reportAccess RoleReportAccess[]
  userRoles    UserRole[]

  @@map("roles")
}

model RoleReportAccess {
  roleId   String @map("role_id") @db.Uuid
  reportId String @map("report_id") @db.Uuid

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@id([roleId, reportId])
  @@map("role_report_access")
}

model User {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @unique
  name       String?
  department String?
  jobTitle   String?  @map("job_title")
  company    String?
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  userRoles   UserRole[]
  preferences UserPreference?
  accessLogs  AccessLog[]

  // NextAuth fields
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserPreference {
  userId        String   @id @map("user_id") @db.Uuid
  pinnedReports String[] @map("pinned_reports") @db.Uuid
  recentReports String[] @map("recent_reports") @db.Uuid
  theme         String   @default("light")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model AccessLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Uuid
  reportId   String?  @map("report_id") @db.Uuid
  accessedAt DateTime @default(now()) @map("accessed_at") @db.Timestamptz

  user   User?   @relation(fields: [userId], references: [id])
  report Report? @relation(fields: [reportId], references: [id])

  @@index([reportId, accessedAt])
  @@index([userId, accessedAt])
  @@map("access_log")
}

// NextAuth required models
model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
